# ════════════════════════════════════════════════
#   AI SECOND BRAIN — Environment Configuration
#   Copy this file to .env and fill in your keys
# ════════════════════════════════════════════════

# ─── LLM Provider ────────────────────────────────
# Options: "claude" | "openai" | "ollama"
LLM_PROVIDER=claude

# ─── Claude (Anthropic) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── OpenAI (fallback or embeddings) ─────────────
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# ─── Ollama (local, free, private) ───────────────
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.2          # or mistral, gemma3, etc.

# ─── Embeddings ──────────────────────────────────
# Options: "local" | "openai" | "voyage"
EMBEDDING_PROVIDER=local
# LOCAL model auto-downloads on first run:
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2
# VOYAGE_API_KEY=pa-your-key-here   # Best quality embeddings

# ─── Vector Database ─────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=second_brain

# ─── Ingestion Settings ──────────────────────────
CHUNK_SIZE=512           # Tokens per chunk
CHUNK_OVERLAP=64         # Overlap between chunks
MAX_RESULTS=8            # How many chunks to retrieve per query

# ─── API Server ──────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-to-a-random-string

# ─── App Settings ────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=./data
RAW_DIR=./data/raw
